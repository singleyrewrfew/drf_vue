# 生产环境配置
# ⚠️ 安全提醒：请勿在生产环境中硬编码服务器 IP 地址
# 推荐使用域名或反向代理（Nginx/Caddy）

# 方案 A：使用域名（推荐 - 需要配合 DNS 和 SSL 证书）
VITE_API_BASE_URL=https://api.yourdomain.com/api
VITE_MEDIA_BASE_URL=https://cdn.yourdomain.com

# 方案 B：相对路径（适用于前后端同域部署）
# VITE_API_BASE_URL=/api
# VITE_MEDIA_BASE_URL=/media

# 方案 C：CI/CD 环境变量注入（推荐用于容器化部署）
# VITE_API_BASE_URL=${API_BASE_URL}
# VITE_MEDIA_BASE_URL=${MEDIA_BASE_URL}
