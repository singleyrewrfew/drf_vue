      "updated": 1,
      "link": null,
      "locked": false,
      "fontSize": 10,
      "fontFamily": 1,
      "text": "api.interceptors.response.use(\n  (response) => {\n    // 1. 解包标准响应格式\n    const { message, data } = response.data\n    \n    // 2. 直接返回 data 部分\n    response.data = data\n    \n    // 3. 返回处理后的响应\n    return response\n  },\n  async (error) => { ... }\n)",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "api.interceptors.response.use(\n  (response) => {\n    // 1. 解包标准响应格式\n    const { message, data } = response.data\n    \n    // 2. 直接返回 data 部分\n    response.data = data\n    \n    // 3. 返回处理后的响应\n    return response\n  },\n  async (error) => { ... }\n)",
      "lineHeight": 1.25,
      "baseline": 9
    },
