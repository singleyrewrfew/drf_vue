      "fontSize": 11,
      "fontFamily": 1,
      "text": "问题: 多个请求同时 401\n解决: 请求队列机制\n\nlet isRefreshing = false\nlet refreshSubscribers = []\n\n// 第一个请求刷新 token\n// 其他请求加入队列等待\n// 刷新完成后统一通知重试",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "问题: 多个请求同时 401\n解决: 请求队列机制\n\nlet isRefreshing = false\nlet refreshSubscribers = []\n\n// 第一个请求刷新 token\n// 其他请求加入队列等待\n// 刷新完成后统一通知重试",
      "lineHeight": 1.25,
      "baseline": 10
    },
