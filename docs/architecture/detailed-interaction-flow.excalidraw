      "roundness": null,
      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "fontSize": 11,
      "fontFamily": 1,
      "text": "api.interceptors.request.use((config) => {\n  const userStore = useUserStore()\n  \n  // 1. 检查是否有 access token\n  if (userStore.accessToken) {\n    // 2. 构建 Authorization 头\n    config.headers['Authorization'] = \n      `Bearer ${userStore.accessToken}`\n  }\n  \n  // 3. 返回修改后的配置\n  return config\n})",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "api.interceptors.request.use((config) => {\n  const userStore = useUserStore()\n  \n  // 1. 检查是否有 access token\n  if (userStore.accessToken) {\n    // 2. 构建 Authorization 头\n    config.headers['Authorization'] = \n      `Bearer ${userStore.accessToken}`\n  }\n  \n  // 3. 返回修改后的配置\n  return config\n})",
      "lineHeight": 1.25,
      "baseline": 10
    },
