      "link": null,
      "locked": false,
      "fontSize": 10,
      "fontFamily": 1,
      "text": "class IsOwnerOrAdmin(BasePermission):\n  def has_object_permission(self, request, view, obj):\n    if request.user.is_admin: return True\n    if hasattr(obj, 'author') and obj.author == request.user:\n      return True\n    return False",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "class IsOwnerOrAdmin(BasePermission):\n  def has_object_permission(self, request, view, obj):\n    if request.user.is_admin: return True\n    if hasattr(obj, 'author') and obj.author == request.user:\n      return True\n    return False",
      "lineHeight": 1.25,
      "baseline": 9
    },
