      "updated": 1,
      "link": null,
      "locked": false,
      "fontSize": 10,
      "fontFamily": 1,
      "text": "if (error.response?.status === 401) {\n  // 1. 使用 refresh token 刷新\n  const newToken = await refreshToken()\n  \n  // 2. 更新请求头\n  originalRequest.headers.Authorization = \n    `Bearer ${newToken}`\n  \n  // 3. 重试原始请求\n  return api(originalRequest)\n}\n// 其他错误直接抛出\nreturn Promise.reject(error)",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "if (error.response?.status === 401) {\n  // 1. 使用 refresh token 刷新\n  const newToken = await refreshToken()\n  \n  // 2. 更新请求头\n  originalRequest.headers.Authorization = \n    `Bearer ${newToken}`\n  \n  // 3. 重试原始请求\n  return api(originalRequest)\n}\n// 其他错误直接抛出\nreturn Promise.reject(error)",
      "lineHeight": 1.25,
      "baseline": 9
    },
