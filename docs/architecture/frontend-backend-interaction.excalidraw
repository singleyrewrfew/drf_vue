    {
      "type": "text",
      "id": "code_evidence_1_text",
      "x": 50,
      "y": 630,
      "width": 260,
      "height": 100,
      "text": "// 请求拦截器\napi.interceptors.request.use((config) => {\n  const userStore = useUserStore()\n  if (userStore.accessToken) {\n    config.headers.Authorization = \n      `Bearer ${userStore.accessToken}`\n  }\n  return config\n})",
      "originalText": "// 请求拦截器\napi.interceptors.request.use((config) => {\n  const userStore = useUserStore()\n  if (userStore.accessToken) {\n    config.headers.Authorization = \n      `Bearer ${userStore.accessToken}`\n  }\n  return config\n})",
      "fontSize": 10,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#22c55e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
