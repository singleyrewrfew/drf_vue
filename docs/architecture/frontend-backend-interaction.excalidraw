      "x": 690,
      "y": 630,
      "width": 260,
      "height": 100,
      "text": "// 401 错误处理\nif (error.response?.status === 401) {\n  // 尝试刷新 Token\n  const newToken = await refreshToken()\n  // 重试原请求\n  return api(originalRequest)\n}",
      "originalText": "// 401 错误处理\nif (error.response?.status === 401) {\n  // 尝试刷新 Token\n  const newToken = await refreshToken()\n  // 重试原请求\n  return api(originalRequest)\n}",
