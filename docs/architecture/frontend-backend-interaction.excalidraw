      "x": 370,
      "y": 630,
      "width": 260,
      "height": 100,
      "text": "// 响应拦截器\napi.interceptors.response.use((response) => {\n  // 提取 data 字段\n  if (responseData?.data) {\n    response.data = responseData.data\n  }\n  return response\n})",
      "originalText": "// 响应拦截器\napi.interceptors.response.use((response) => {\n  // 提取 data 字段\n  if (responseData?.data) {\n    response.data = responseData.data\n  }\n  return response\n})",
