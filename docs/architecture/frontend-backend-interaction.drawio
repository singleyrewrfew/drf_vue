        <mxCell id="refresh_desc" value="当 Access Token 过期时（401 错误），前端自动使用 Refresh Token 获取新的 Token：&#xa;&#xa;1. 请求拦截器检测到 401 错误&#xa;2. 使用 refresh token 调用 POST /api/auth/refresh/&#xa;3. 后端验证 refresh token 并生成新的 access token&#xa;4. 前端更新 localStorage 中的 token&#xa;5. 使用新 token 重试原请求" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;sketch=1;curveFuzzy=1;" parent="1" vertex="1">
          <mxGeometry x="55" y="330" width="380" height="110" as="geometry" />
        </mxCell>
        <mxCell id="refresh_flow" value="401 Error → 拦截器 → POST /auth/refresh/ → 新 Token → 重试请求" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;curveFuzzy=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=center;verticalAlign=middle;" parent="1" vertex="1">
          <mxGeometry x="460" y="370" width="400" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
