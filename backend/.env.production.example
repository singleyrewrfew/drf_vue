# Django 配置 - 生产环境
# ⚠️  重要：请根据实际生产环境修改以下配置

# ==================== 安全配置 ====================
# 必须设置强随机密钥（使用 python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())" 生成）
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production

# 生产环境必须关闭 DEBUG
DJANGO_DEBUG=False

# 允许的域名（多个用逗号分隔）
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com,api.your-domain.com

# ==================== CORS 配置 ====================
# 前端域名列表
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ==================== 数据库配置（MySQL/MariaDB）====================
DB_ENGINE=django.db.backends.mysql
DB_NAME=cms_production
DB_USER=cms_user
DB_PASSWORD=strong-password-here
DB_HOST=localhost
DB_PORT=3306

# MySQL 连接池配置（生产环境推荐）
# CONN_MAX_AGE: 300秒（5分钟），平衡性能和资源占用
# CONN_HEALTH_CHECKS: True，启用健康检查避免使用失效连接
DB_CONN_MAX_AGE=300
DB_CONN_HEALTH_CHECKS=True

# ==================== Redis 配置 ====================
# Redis URL 格式：redis://[:password]@host:port/db
REDIS_URL=redis://127.0.0.1:6379/1
REDIS_CACHE_URL=redis://127.0.0.1:6379/1
CACHE_KEY_PREFIX=cms_prod

# ==================== Celery 配置 ====================
CELERY_BROKER_URL=redis://127.0.0.1:6379/2
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/3

# ==================== JWT 配置 ====================
# Access Token 有效期（分钟）
JWT_ACCESS_TOKEN_LIFETIME=60
# Refresh Token 有效期（分钟）
JWT_REFRESH_TOKEN_LIFETIME=1440

# ==================== FFmpeg 配置 ====================
FFMPEG_PATH=/usr/bin/ffmpeg
FFMPEG_ADDITIONAL_PATHS=/usr/local/bin,/opt/ffmpeg/bin

# ==================== Nginx 配置 ====================
# 是否使用 Nginx X-Accel-Redirect 传输媒体文件
USE_NGINX_ACCEL_REDIRECT=True

# ==================== 日志配置 ====================
LOG_LEVEL=WARNING
LOG_DIR=/var/log/django
