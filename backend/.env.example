# Django 配置
# ⚠️ 生产环境必须设置 DJANGO_SECRET_KEY，否则启动失败
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production

# ⚠️ 开发环境默认 False，需要开启调试模式请设为 True
DJANGO_DEBUG=False

# 开发环境可临时添加允许的域名
DJANGO_DEBUG_ALLOWED_HOSTS=localhost,127.0.0.1

# 生产环境允许的主机域名（生产部署时设置）
# DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# CORS 允许的前端域名（多个用逗号分隔）
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# ⚠️ 开发环境如需允许所有来源，设为 True（生产环境必须 False）
CORS_ALLOW_ALL_FOR_DEV=False

# 数据库配置
# ⚠️ 开发环境使用 SQLite，生产环境建议使用 MySQL/MariaDB

# 方案一：SQLite（开发环境默认）
# DB_ENGINE=django.db.backends.sqlite3
# SQLITE_DB_NAME=db.sqlite3

# 方案二：MySQL/MariaDB（生产环境推荐）
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=cms_db
# DB_USER=cms_user
# DB_PASSWORD=your_secure_password_here
# DB_HOST=localhost
# DB_PORT=3306

# MySQL 连接池配置（可选）
# DB_CONN_MAX_AGE=600
# DB_CONN_HEALTH_CHECKS=True

# FFmpeg 配置（Windows 示例）
# FFMPEG_PATH=D:\ffmpeg\bin
# FFMPEG_ADDITIONAL_PATHS=D:\ffmpeg\bin,C:\ffmpeg\bin

# FFmpeg 配置（Linux 示例）
# FFMPEG_PATH=/usr/bin
# FFMPEG_ADDITIONAL_PATHS=/usr/local/bin
