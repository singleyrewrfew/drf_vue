# GitHub Actions 环境变量示例
# 复制此文件为 .env.production 并填写实际值

###############################################################################
# Django 核心配置
###############################################################################

# ⚠️ 生产环境必须使用强密钥（建议使用 Django 生成）
# 生成方法: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production

# 生产环境必须设为 False
DJANGO_DEBUG=False

# 允许的域名（多个用逗号分隔）
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com,8.148.251.135

# CSRF 信任域名（与 ALLOWED_HOSTS 保持一致）
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

###############################################################################
# 数据库配置
###############################################################################

# 方案一：PostgreSQL（推荐）
DB_ENGINE=django.db.backends.postgresql
DB_NAME=drf_vue_db
DB_USER=drf_vue_user
DB_PASSWORD=your-database-password
DB_HOST=localhost
DB_PORT=5432

# 连接池配置
DB_CONN_MAX_AGE=600
DB_CONN_HEALTH_CHECKS=True

# 方案二：MySQL/MariaDB（备选）
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=drf_vue_db
# DB_USER=drf_vue_user
# DB_PASSWORD=your-database-password
# DB_HOST=localhost
# DB_PORT=3306

# 方案三：SQLite（仅用于测试）
# DB_ENGINE=django.db.backends.sqlite3
# SQLITE_DB_NAME=db.sqlite3

###############################################################################
# CORS 配置
###############################################################################

# 允许的前端域名（多个用逗号分隔）
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# 生产环境必须设为 False
CORS_ALLOW_ALL_FOR_DEV=False

# 允许的请求头
CORS_ALLOW_HEADERS=content-type,authorization,x-csrftoken

# 允许的方法
CORS_ALLOW_METHODS=DELETE,GET,OPTIONS,PATCH,POST,PUT

# 允许携带凭证
CORS_ALLOW_CREDENTIALS=True

###############################################################################
# JWT 配置
###############################################################################

# Access Token 有效期
SIMPLE_JWT_ACCESS_TOKEN_LIFETIME=minutes=60

# Refresh Token 有效期
SIMPLE_JWT_REFRESH_TOKEN_LIFETIME=days=7

# Token 类型
SIMPLE_JWT_AUTH_HEADER_TYPE=Bearer

###############################################################################
# 媒体文件和静态文件配置
###############################################################################

# 媒体文件根目录（用户上传的文件）
MEDIA_ROOT=/home/DRF_VUE/drf_vue/backend/media
MEDIA_URL=/media/

# 静态文件根目录（collectstatic 收集的位置）
STATIC_ROOT=/home/DRF_VUE/drf_vue/backend/staticfiles
STATIC_URL=/static/

###############################################################################
# 日志配置
###############################################################################

# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE_PATH=/var/log/gunicorn/django.log

###############################################################################
# Email 配置（可选，用于密码重置等）
###############################################################################

# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-email-password
# DEFAULT_FROM_EMAIL=your-email@gmail.com

###############################################################################
# Redis 配置（可选，用于缓存和 Celery）
###############################################################################

# REDIS_URL=redis://localhost:6379/0
# REDIS_CACHE_URL=redis://localhost:6379/1

###############################################################################
# Celery 配置（可选，用于异步任务）
###############################################################################

# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

###############################################################################
# 其他配置
###############################################################################

# 时区设置
TIME_ZONE=Asia/Shanghai

# 语言设置
LANGUAGE_CODE=zh-hans

# 是否启用 HTTPS
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# HSTS 设置
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# X-Frame-Options
X_FRAME_OPTIONS=DENY

# Content Security Policy
SECURE_CONTENT_TYPE_NOSNIFF=True
